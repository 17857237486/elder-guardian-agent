APP_ENV=development
ELDER_ID=elder_001

MQTT_HOST=localhost
MQTT_PORT=1883

DATABASE_URL=sqlite:///../../data/guardian.db

LLM_BASE_URL=http://172.30.0.1:8001/v1
LLM_API_KEY=local-rk3588
LLM_MODEL=internvl3.5-4b-rk3588
# v1 guardian-core stays on mock so it does not occupy the RK3588 local VLM.
CORE_LLM_MOCK=true
# v2 guardian-orchestrator uses the RK3588 local model by default.
LLM_MOCK=false
LLM_TIMEOUT_SEC=120
LLM_MAX_TOKENS=1024
LLM_MAX_CONCURRENT_WORKFLOWS=1
LLM_CHAIN_TIMEOUT_SEC=300
LLM_STEP_RETRIES=1
P3_ENVIRONMENT_COOLDOWN_SEC=120

# Local multimodal vision and optional cloud review
SNAPSHOT_ROOT=/app/data/snapshots
VISION_API_BASE=http://vision-service:8101
VISION_FRAME_WAIT_SEC=5
VISION_RETENTION_DAYS=7
VISION_BUFFER_SECONDS=12
VISION_MAX_IMAGE_BYTES=5242880
VISION_MAX_IMAGE_EDGE=1280
VISION_JPEG_QUALITY=80
# Example: {"living_room":"http://192.168.10.20/snapshot.jpg"}
VISION_CAMERA_SNAPSHOT_URLS=
CLOUD_LLM_ENABLED=false
CLOUD_LLM_BASE_URL=
CLOUD_LLM_API_KEY=
CLOUD_LLM_MODEL=
CLOUD_LLM_TIMEOUT_SEC=60

EDGE_API_BASE=http://localhost:8010
ORCHESTRATOR_URL=http://localhost:8020
SIMULATE_DEVICE_WHEN_MQTT_UNAVAILABLE=true
# Current demo mode: personal baselines are set manually from the 8090 page.
AUTO_PERSONAL_BASELINE_ENABLED=false
AUTO_CANDIDATE_ENABLED=true

HMI_RESPONSE_TIMEOUT_SEC=30
DASHBOARD_WS_PATH=/ws/dashboard
WECHAT_MOCK=true

# Browser-facing URLs must be reachable from the device opening the UI.
PUBLIC_GUARDIAN_API_BASE=http://localhost:8000
PUBLIC_EDGE_API_BASE=http://localhost:8010

GUARDIAN_CORE_URL=http://localhost:8000
VISION_SERVICE_URL=http://vision-service:8101
BACKGROUND_MAX_RECORDS=3100

# Optional host-port overrides allow multiple stacks to run on one machine.
MQTT_PUBLIC_PORT=1883
CORE_PUBLIC_PORT=8000
EDGE_PUBLIC_PORT=8010
ORCHESTRATOR_PUBLIC_PORT=8020
BACKGROUND_PUBLIC_PORT=8090
VISION_PUBLIC_PORT=8101
WECHAT_PUBLIC_PORT=8102
DASHBOARD_PUBLIC_PORT=5173
HMI_PUBLIC_PORT=5174

# Prebuilt-image deployments set these in .env.
# IMAGE_PREFIX=ghcr.io/your-org/elder-guardian-agent
# IMAGE_TAG=latest
