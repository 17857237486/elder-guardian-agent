APP_ENV=development
ELDER_ID=elder_001

MQTT_HOST=localhost
MQTT_PORT=1883

DATABASE_URL=sqlite:///../../data/guardian.db

LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=change-me
LLM_MODEL=qwen2.5:7b
LLM_MOCK=true
LLM_TIMEOUT_SEC=120
LLM_MAX_TOKENS=1024
LLM_MAX_CONCURRENT_WORKFLOWS=1
LLM_CHAIN_TIMEOUT_SEC=120
LLM_STEP_RETRIES=1

EDGE_API_BASE=http://localhost:8010
ORCHESTRATOR_URL=http://localhost:8020
SIMULATE_DEVICE_WHEN_MQTT_UNAVAILABLE=true

HMI_RESPONSE_TIMEOUT_SEC=30
DASHBOARD_WS_PATH=/ws/dashboard
WECHAT_MOCK=true

# Browser-facing URLs must be reachable from the device opening the UI.
PUBLIC_GUARDIAN_API_BASE=http://localhost:8000
PUBLIC_EDGE_API_BASE=http://localhost:8010

GUARDIAN_CORE_URL=http://localhost:8000
BACKGROUND_MAX_RECORDS=1000

# Optional host-port overrides allow multiple stacks to run on one machine.
MQTT_PUBLIC_PORT=1883
CORE_PUBLIC_PORT=8000
EDGE_PUBLIC_PORT=8010
ORCHESTRATOR_PUBLIC_PORT=8020
BACKGROUND_PUBLIC_PORT=8090
VISION_PUBLIC_PORT=8101
WECHAT_PUBLIC_PORT=8102
DASHBOARD_PUBLIC_PORT=5173
HMI_PUBLIC_PORT=5174

# Prebuilt-image deployments set these in .env.
# IMAGE_PREFIX=ghcr.io/your-org/elder-guardian-agent
# IMAGE_TAG=latest
